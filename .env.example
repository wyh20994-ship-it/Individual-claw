# ============================================================
# HangClaw Environment Variables
# 复制为 .env 并填入真实值
# ============================================================

# --- Gateway ---
GATEWAY_PORT=3000
GATEWAY_WS_PORT=3001

# --- Runner ---
RUNNER_WS_URL=ws://127.0.0.1:3001

# --- LLM Providers ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CLAUDE_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_LLM_MODEL=deepseek-chat

# --- Channels ---
# QQ Bot
QQ_APP_ID=
QQ_APP_SECRET=
QQ_TOKEN=

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# DingTalk
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_ROBOT_CODE=

# --- Memory ---
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
MEMORY_CONVERSATIONS_DIR=./data/memory/conversations
MEMORY_TTL_SECONDS=3600

# --- Services ---
AMAP_API_KEY=
TAVILY_API_KEY=
TAVILY_PUSH_CRON=0 8 * * *

# --- Security ---
BASH_WHITELIST_COMMANDS=ls,cat,head,tail,wc,grep,find,echo,date
SANDBOX_BASE_PATH=./data/sandbox
