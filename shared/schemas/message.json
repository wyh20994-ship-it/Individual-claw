{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HangClaw Unified Message",
  "description": "Gateway 与 Runner 之间传递的统一消息格式",
  "type": "object",
  "required": ["channel", "userId", "content", "messageId"],
  "properties": {
    "channel": {
      "type": "string",
      "enum": ["qq", "feishu", "dingtalk"],
      "description": "消息来源渠道"
    },
    "userId": {
      "type": "string",
      "description": "用户唯一标识"
    },
    "userName": {
      "type": "string",
      "description": "用户名（可选）"
    },
    "groupId": {
      "type": "string",
      "description": "群组 ID（可选）"
    },
    "content": {
      "type": "string",
      "description": "消息文本内容"
    },
    "messageId": {
      "type": "string",
      "description": "原始消息 ID"
    },
    "timestamp": {
      "type": "number",
      "description": "消息时间戳 (ms)"
    },
    "raw": {
      "type": "object",
      "description": "原始渠道数据"
    }
  }
}
